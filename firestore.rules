rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Products Collection Rules
    // - Anyone can read product details.
    // - Only authenticated administrator users can write (create, update, delete).
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Inquiries Collection Rules
    // - Anyone can create an inquiry (customers submit inquiries).
    // - Only authenticated administrators can read and update/delete inquiries.
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
